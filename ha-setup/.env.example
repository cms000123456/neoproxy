# NeoProxy HA Configuration
# Copy to .env and customize for each controller

# ============================================================================
# CONTROLLER IDENTITY
# ============================================================================

# Role of this controller: master, backup1, backup2
CONTROLLER_ROLE=master

# Unique router ID for keepalived (must be different for each controller)
ROUTER_ID=51

# VRRP Priority (higher = preferred master)
# MASTER: 100, BACKUP1: 90, BACKUP2: 80
PRIORITY=100

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Network interface for VRRP (eth0, ens192, etc.)
INTERFACE=eth0

# Virtual/Floating IP that will move between controllers
VIRTUAL_IP=203.0.113.10

# Netmask for virtual IP
VIRTUAL_IP_NETMASK=24

# ============================================================================
# SHARED STORAGE
# ============================================================================

# Path to shared storage (GlusterFS mount or NFS)
# For GlusterFS: /mnt/neoproxy-data
# For local (non-HA): ./data
SHARED_DATA_PATH=/mnt/neoproxy-data

# GlusterFS volume name (if using Gluster)
GLUSTER_VOLUME=neoproxy-data

# GlusterFS controller IPs (comma-separated)
GLUSTER_CONTROLLERS=192.168.1.10,192.168.1.11,192.168.1.12

# ============================================================================
# AUTHENTIK SECRETS (must be same on all controllers!)
# ============================================================================

# PostgreSQL password
PG_PASS=change_this_secure_password

# Authentik secret key (50+ characters, same on all nodes)
AUTHENTIK_SECRET_KEY=your_very_long_secret_key_here_min_50_chars

# ============================================================================
# NEBULA VPN (for inter-host connectivity)
# ============================================================================

# Public IP of the master controller (for spokes to connect)
NEBULA_PUBLIC_IP=203.0.113.10

# ============================================================================
# NOTIFICATIONS (optional)
# ============================================================================

# Slack webhook for HA notifications
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email for notifications
# NOTIFICATION_EMAIL=admin@yourdomain.com
