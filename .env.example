# PostgreSQL Configuration
PG_PASS=change_this_to_a_secure_password
PG_USER=authentik
PG_DB=authentik

# Authentik Secret Key - Generate with: openssl rand -base64 48
AUTHENTIK_SECRET_KEY=change_this_to_a_50_char_random_string

# Optional: Email configuration for notifications/password resets
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Outpost token (for LDAP/RADIUS outposts if needed)
# OUTPOST_TOKEN=your_outpost_token

# Domain Configuration
DOMAIN=yourdomain.com
AUTH_SUBDOMAIN=auth
